# Full production checklist (Vercel project easyintake-app-web + Clerk Production):
#   see DEPLOY-PRODUCTION.md in this folder.
#
# Option A: Symlink to root .env (pulls Clerk keys from monorepo root)
#   ln -sf ../../.env .env.local
#
# Option B: Copy Clerk keys into this file (if not using symlink)
#
# --- Clerk (https://dashboard.clerk.com) — Development instance for local dev ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Path-based sign-in/up (default locale en; Spanish uses /es/... in-app via ClerkProvider)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/en/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/en/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/en/dashboard/queue
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/en/dashboard/queue
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/en/dashboard/queue
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/en/dashboard/queue

# --- Vercel (project: easyintake-app-web) ---
# In the Vercel project, set Root Directory to `apps/web` (this package).
# This folder includes `vercel.json` so install/build run from the monorepo root
# and resolve workspace package `@easy-intake/shared`.
# Copy the variables above into the Vercel project (Settings → Environment Variables).
# Use Production keys for Production, Development keys for Preview if you want.

# --- Clerk production (after Vercel has a stable URL) ---
# 1. In Clerk Dashboard, create or select the Production instance.
# 2. Add your deployment origin (e.g. https://easyintake-app-web.vercel.app) under
#    Domains / allowed origins / redirect URLs as required by Clerk for your deployment.
# 3. Add paths for both locales, e.g.:
#    .../en/sign-in, .../es/sign-in, .../en/sign-up, .../es/sign-up
# 4. Replace NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY and CLERK_SECRET_KEY in Vercel Production
#    with the Production instance keys.

# --- Organization logos (Vercel Blob) — Settings → Organization upload / rehost after fetch ---
# Create a Blob store in Vercel → Storage → Connect to this project; copy read-write token.
BLOB_READ_WRITE_TOKEN=
# Optional: canonical browser origin for redirects and absolute URLs (e.g. https://app.easyintakeapp.com)
# NEXT_PUBLIC_APP_URL=

# --- Voice agent bridge (must match apps/api API_JWT_SECRET) ---
API_JWT_SECRET=
# API origin (Railway). Used to resolve /public/agent.html if NEXT_PUBLIC_AGENT_HTML_URL is unset.
NEXT_PUBLIC_API_URL=http://localhost:3001
# Optional: full base for agent static host; defaults to NEXT_PUBLIC_API_URL
NEXT_PUBLIC_AGENT_HTML_URL=http://localhost:3001

# Optional: server-side BFF calls to Railway (same value as NEXT_PUBLIC_API_URL in many setups)
# API_BASE_URL=https://your-api.up.railway.app

# --- Applicant microsite (public /en|es/apply/[token]) ---
# Full applicant URLs in SMS and API mint responses are built on apps/api using
# APPLICANT_PORTAL_BASE_URL (set there / Railway — NOT in this Vercel project).
# This app only needs NEXT_PUBLIC_API_URL + API_JWT_SECRET for BFF routes.

