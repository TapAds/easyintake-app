# Option A: Symlink to root .env (pulls Clerk keys from monorepo root)
#   ln -sf ../../.env .env.local
#
# Option B: Copy Clerk keys into this file (if not using symlink)
# Clerk (get keys from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/en
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/en
