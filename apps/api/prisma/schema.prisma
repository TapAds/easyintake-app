// This is your Prisma schema file.
// Learn more at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CallStatus {
  ACTIVE
  COMPLETED
  FAILED
  NO_ANSWER
}

enum FlowStage {
  QUOTE_COLLECTION  // collecting minimum fields required to generate a quote
  QUOTE_READY       // quote fields complete — quote engine call happens here (Phase 2)
  PRODUCT_SELECTED  // agent and applicant have chosen a carrier and product
  FULL_APPLICATION  // all underwriting and application fields collected
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  UNKNOWN
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Call {
  id                 String     @id @default(cuid())
  callSid            String     @unique
  from               String     // caller E.164 phone
  to                 String     // agency Twilio number E.164
  startedAt          DateTime
  endedAt            DateTime?
  durationSeconds    Int?
  status             CallStatus @default(ACTIVE)
  consentVerbal      Boolean    @default(false)
  consentTimestamp   DateTime?
  completenessScore  Float      @default(0)
  flowStage          FlowStage  @default(QUOTE_COLLECTION)
  agentDecisionMade  Boolean    @default(false)
  selectedCarrier    String?    // set when flowStage = PRODUCT_SELECTED
  selectedProduct    String?    // set when flowStage = PRODUCT_SELECTED
  ghlContactId       String?
  ghlOpportunityId   String?    // only populated after agent explicitly acts on suggestion
  ghlSyncedAt        DateTime?
  detectedLanguages  String[]   @default([]) // ISO-639-1 codes detected during call
  primaryLanguage    String?    // ISO-639-1 code of dominant language
  intakeSessionId    String?
  /// Intake sessions created later from this call's stored transcript (different product / application).
  derivedIntakeSessions IntakeSession[] @relation("IntakeSessionSourceCall")
  /// Append-only JSON array of field-level edits (see FieldChangeEventV1 in apps/api)
  fieldChangeLog     Json       @default("[]")
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  intakeSession      IntakeSession?       @relation("CallPrimaryIntakeSession", fields: [intakeSessionId], references: [id], onDelete: SetNull)
  entity             LifeInsuranceEntity?
  transcriptSegments TranscriptSegment[]
  followUpJobs       FollowUpJob[] // post-call jobs only (callId set; intakeSessionId null)
  complianceLogs     ComplianceLog[]
}

// Vertical-agnostic intake session (dashboard / queue). Mirrors packages/shared IntakeSession.
model IntakeSession {
  id                 String   @id @default(cuid())
  organizationId     String
  verticalId         String
  configPackageId    String
  status             String   @default("collecting") // IntakeSessionStatus string
  substatus          String?
  primaryChannel     String?  @default("voice")
  completenessScore         Float    @default(0)
  /// N-400 workflow: share of required evidence items satisfied [0–1] (see `requirementsJson` + attachments).
  evidenceCompletenessScore   Float    @default(0)
  fieldValues        Json     @default("{}")
  channels           Json     @default("[]")
  hitl               Json     @default("{}")
  externalIds        Json?
  /// Append-only JSON array of field-level edits (cross-channel audit)
  fieldChangeLog     Json     @default("[]")
  configTemplateId   String?
  /// When set, field values were seeded from this call's transcript (new application / product). Primary leg uses Call.intakeSessionId.
  sourceCallId       String?
  sourceCall         Call?    @relation("IntakeSessionSourceCall", fields: [sourceCallId], references: [id], onDelete: SetNull)

  template IntakeFieldTemplate? @relation(fields: [configTemplateId], references: [id], onDelete: SetNull)
  calls        Call[] @relation("CallPrimaryIntakeSession")
  attachments  IntakeAttachment[]
  signatureRequests SignatureRequest[]
  followUpJobs FollowUpJob[]
  workflowInstance  WorkflowInstance?

  applicantPortalAccesses ApplicantPortalAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, updatedAt])
  @@index([configPackageId])
  @@index([sourceCallId])
}

/// Time-limited opaque token for applicant self-service (microsite); store hash only.
model ApplicantPortalAccess {
  id               String        @id @default(cuid())
  intakeSessionId  String
  intakeSession    IntakeSession @relation(fields: [intakeSessionId], references: [id], onDelete: Cascade)
  tokenHash        String        @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime?
  createdAt        DateTime      @default(now())

  @@index([intakeSessionId])
  @@index([expiresAt])
}

/// Phase 4 — GHL Documents & Contracts: template send, signature completion webhooks, reminder nudges.
model SignatureRequest {
  id              String   @id @default(cuid())
  intakeSessionId String?
  intakeSession   IntakeSession? @relation(fields: [intakeSessionId], references: [id], onDelete: SetNull)

  ghlLocationId  String
  ghlContactId   String
  ghlTemplateId  String
  /// Set when GHL returns a document / proposal instance id (shape varies by API version).
  ghlDocumentId  String?

  /// pending_send | sent | signed | declined | expired | failed | cancelled
  status        String    @default("pending_send")
  reminderCount Int       @default(0)
  maxReminders  Int       @default(5)
  nextReminderAt DateTime?
  lastError     String?  @db.Text

  /// GHL webhook id that completed this request (for support / audits).
  signedWebhookId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sentAt    DateTime?
  signedAt  DateTime?

  @@index([ghlLocationId, ghlContactId])
  @@index([status, nextReminderAt])
  @@index([intakeSessionId])
}

/// Applicant document received via GHL (SMS/MMS, WhatsApp, email). Phase 3 — fetch + vision/PDF extraction audit trail.
model IntakeAttachment {
  id               String   @id @default(cuid())
  intakeSessionId  String
  intakeSession    IntakeSession @relation(fields: [intakeSessionId], references: [id], onDelete: Cascade)
  ghlMessageId     String?
  ghlContactId     String
  inboundChannel   String
  sourceUrl        String   @db.Text
  mimeType         String?
  byteSize         Int
  sha256           String
  /// fetched | extracted | failed | skipped
  status           String
  errorMessage     String?  @db.Text
  extractedPreview Json?

  createdAt DateTime @default(now())

  @@index([intakeSessionId, createdAt])
  @@index([sha256, intakeSessionId])
}

// Field catalog for a product/form; created or updated during org onboarding.
model IntakeFieldTemplate {
  id               String   @id @default(cuid())
  organizationId   String
  configPackageId  String
  name             String?
  fieldDefinitions Json     @default("[]")

  sessions IntakeSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, configPackageId])
}

model LifeInsuranceEntity {
  id      String @id @default(cuid())
  callId  String @unique
  call    Call   @relation(fields: [callId], references: [id], onDelete: Cascade)

  // Identity
  firstName   String?
  lastName    String?
  dateOfBirth DateTime? // stored as DateTime; time portion is always midnight UTC
  gender      Gender?

  // Contact
  phone    String?
  email    String?
  address  String?
  city     String?
  state    String?   // 2-char US state code
  zip      String?

  // Coverage needs
  coverageAmountDesired Int?    // face value in dollars (e.g. 500000)
  productTypeInterest   String? // "term" | "whole" | "universal" | "final_expense"
  termLengthDesired     Int?    // years (10, 15, 20, 25, 30)
  budgetMonthly         Int?    // max monthly premium in dollars

  // Underwriting signals
  tobaccoUse             Boolean?
  tobaccoLastUsed        String?  // "never" | "<1yr" | "1-3yr" | "3+yr"
  heightFeet             Int?
  heightInches           Int?
  weightLbs              Int?
  existingCoverage       Boolean?
  existingCoverageAmount Int?     // existing death benefit in dollars

  // Beneficiary (primary only)
  beneficiaryName     String?
  beneficiaryRelation String?

  // Multi-language audit
  originalLanguages String[] @default([]) // ISO-639-1 codes present in extracted text
  rawExtractedText  Json?    // raw utterances that drove extraction, keyed by languageCode

  // Audit
  extractedByAI   Json?
  agentCorrected  Boolean  @default(false)
  lastCorrectedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TranscriptSegment {
  id           String   @id @default(cuid())
  callId       String
  call         Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  speaker      String   // "agent" | "caller" | "unknown"
  text         String
  offsetMs     Int      // milliseconds from call start
  languageCode String   @default("en") // ISO-639-1 (e.g. "en", "es", "fr")
  confidence   Float?                  // STT confidence score from Deepgram (0.0–1.0)
  createdAt    DateTime @default(now())
}

model FollowUpJob {
  id           String    @id @default(cuid())
  /// Post-voice follow-up (Twilio call). Null when this job targets a GHL-only IntakeSession.
  callId       String?
  call         Call?     @relation(fields: [callId], references: [id], onDelete: Cascade)
  /// After inbound GHL messages — Smart Chaser when quote fields are still missing (Phase 5).
  intakeSessionId String?
  intakeSession   IntakeSession? @relation(fields: [intakeSessionId], references: [id], onDelete: Cascade)
  /// Insurance entity field key (e.g. dateOfBirth) driving template-safe gap_reminder copy.
  chaserFieldKey  String?
  status       String    @default("PENDING") // PENDING | SENDING | SENT | FAILED | CANCELLED
  scheduledFor DateTime
  sentAt       DateTime?
  failReason   String?
  /// SMS | EMAIL | WHATSAPP — preferred outbound channel (sticky; Phase 2+ from inbound)
  outreachChannel String   @default("SMS")
  /// Set when send succeeds: GoHighLevel message id from Conversations API, or Twilio MessageSid
  externalMessageId String?
  /// ghl | twilio — which provider actually sent the message
  outreachProvider  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([intakeSessionId])
}

/// Idempotent receipt log for GoHighLevel marketplace webhooks (duplicate webhookId = no-op).
model GhlWebhookReceipt {
  webhookId  String   @id
  eventType  String?
  receivedAt DateTime @default(now())
}

/// Deduplicate InboundMessage processing when GHL retries or sends duplicate deliveries.
model GhlProcessedInboundMessage {
  messageId   String   @id
  locationId  String
  contactId   String
  processedAt DateTime @default(now())

  @@index([locationId, contactId])
}

model AgencyConfig {
  id                     String   @id @default(cuid())
  ghlLocationId          String   @unique
  /// When set, dashboard JWT org scope includes `ghl:{ghlLocationId}` for this sub-account (links Clerk org to voice/GHL-created sessions).
  clerkOrganizationId    String?
  ghlAccessToken         String
  ghlRefreshToken        String
  ghlTokenExpiresAt      DateTime
  agencyName             String   @default("Easy Intake Agency")
  twilioAccountSid       String
  twilioPhoneNumber      String // E.164 format
  /// When set, inbound TwiML uses Conference + outbound dial so this PSTN/SIP number rings into the same room (keeps Media Stream on the Twilio leg). Overrides VOICE_AGENT_FORWARD_NUMBER for this agency.
  voiceAgentForwardNumber String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([clerkOrganizationId])
}

model ComplianceLog {
  id           String   @id @default(cuid())
  callId       String
  call         Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  inputText    String   // raw AI output before filtering
  outputText   String   // filtered text shown to agent
  wasModified  Boolean
  flaggedTerms String[]
  createdAt    DateTime @default(now())
}

// ─── Intake webhook (cotizarahora → easyappintake) ─────────────────────────────

model IntakeLead {
  id             String   @id @default(cuid())
  leadId         String   @unique // UUID from cotizarahora — idempotency key
  ghlContactId   String?  // GHL contact ID after upsert
  lastEvent      String   // lead.captured | quote.completed | quote.requested_callback
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Workflow agent (N-400 / long-running intake) ─────────────────────────────

/// 1:1 with IntakeSession — durable case state for multi-channel workflow (Release A+).
model WorkflowInstance {
  id                 String         @id @default(cuid())
  intakeSessionId    String         @unique
  intakeSession      IntakeSession  @relation(fields: [intakeSessionId], references: [id], onDelete: Cascade)

  /// INITIAL_INTAKE | PRE_ELIGIBLE_COLLECTION | PENDING_DOCS | VERIFYING | AUDIT_READY | ESCALATED | ESCALATED_CONFLICT | ESCALATED_LEGAL_REVIEW | CLOSED
  phase              String         @default("INITIAL_INTAKE")
  /// First day applicant may file with USCIS (90-day early filing rule); denormalized from rules.
  targetSubmissionDate             DateTime?      @db.Date
  /// End of continuous residence period (LPR + 3/5 years); denormalized for dashboard.
  continuousResidenceCompleteDate DateTime?     @db.Date
  /// Dynamic evidence checklist + statuses (see packages/shared uscisN400/rules.ts).
  requirementsJson   Json           @default("[]")
  preferredChannel   String?        // sms | whatsapp | voice | web

  nudgeCount         Int            @default(0)
  maxNudges          Int            @default(3)
  lastNudgeAt        DateTime?
  silenceWindowHours Int            @default(22)
  nextAllowedNudgeAt DateTime?

  escalationReason   String?        @db.Text
  escalatedAt        DateTime?
  assignedToUserId   String?

  lastIngestionAt    DateTime?
  lastChannel        String?

  events             WorkflowEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phase])
}

/// Append-only audit trail for workflow / orchestrator (Release A+).
model WorkflowEvent {
  id                 String           @id @default(cuid())
  workflowInstanceId String
  workflowInstance   WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  type               String
  payload            Json             @default("{}")

  createdAt DateTime @default(now())

  @@index([workflowInstanceId, createdAt])
}
