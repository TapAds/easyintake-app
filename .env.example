# ─── Database ────────────────────────────────────────────────────────────────
# Postgres connection string. Default matches docker-compose.yml.
DATABASE_URL="postgresql://easyintake:easyintake@localhost:5432/easyintake"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Public base URL of this server (used to build TwiML Stream URL).
# In development, use your ngrok HTTPS URL (e.g. https://abc123.ngrok.io).
# In production, use your deployed domain.
PUBLIC_BASE_URL="https://your-ngrok-subdomain.ngrok.io"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Static JWT used by the agent browser and internal API calls.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
API_JWT_SECRET="replace-with-a-long-random-secret"

# ─── Twilio ──────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
# The Twilio phone number that receives/makes calls (E.164 format)
TWILIO_PHONE_NUMBER="+15550000000"

# ─── Deepgram ────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY="your-deepgram-api-key"

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ─── GoHighLevel ─────────────────────────────────────────────────────────────
GHL_LOCATION_ID="your-ghl-location-id"
# OAuth2 tokens — stored in DB after initial setup; these are used to seed AgencyConfig.
GHL_ACCESS_TOKEN="your-ghl-access-token"
GHL_REFRESH_TOKEN="your-ghl-refresh-token"
# GHL OAuth2 app credentials (for token refresh)
GHL_CLIENT_ID="your-ghl-client-id"
GHL_CLIENT_SECRET="your-ghl-client-secret"
# Optional: for creating opportunities on qualified leads (score >= 0.7)
# GHL_PIPELINE_ID=
# GHL_PIPELINE_STAGE_ID=

# ─── Intake webhook (cotizarahora) ────────────────────────────────────────────
# Shared secret for POST /api/webhooks/intake. Must match cotizarahora's EASYAPPINTAKE_WEBHOOK_SECRET.
# COTIZARAHORA_WEBHOOK_SECRET=
